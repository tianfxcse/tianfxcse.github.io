<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>跨职能流程图 - 状态与角色矩阵</title>
    <!-- 引入 Vue.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/vue@2.7.14/dist/vue.js"></script>
    <!-- 引入 Font Awesome 6 (免费图标库，增强视觉) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- 自定义样式 -->
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            margin: 0;
            padding: 20px;
        }

        .app-container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            overflow-x: auto;
            padding: 20px;
        }

        h1 {
            font-size: 1.6rem;
            margin: 0 0 0.5rem 0;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sub {
            color: #475569;
            border-left: 3px solid #3b82f6;
            padding-left: 12px;
            margin-bottom: 24px;
            font-size: 0.9rem;
        }

        /* 图表包装器，支持横向滚动 */
        .diagram-wrapper {
            overflow-x: auto;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            background: #ffffff;
        }

        .swimlane-container {
            min-width: 700px;
        }

        /* 表格布局: 首列为角色头，后续每列为一个状态 */
        .matrix {
            display: table;
            width: 100%;
            border-collapse: collapse;
        }

        .matrix-row {
            display: table-row;
        }

        /* 角色头单元格 (第一列) */
        .role-header-cell {
            display: table-cell;
            background: #f8fafc;
            font-weight: 600;
            border: 1px solid #e2e8f0;
            padding: 14px 12px;
            vertical-align: middle;
            text-align: center;
            min-width: 130px;
            background-color: #f1f5f9;
            color: #0f172a;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
        }

        /* 状态列头 (顶部) */
        .state-header-cell {
            display: table-cell;
            background: #eef2ff;
            font-weight: 700;
            border: 1px solid #e2e8f0;
            padding: 14px 8px;
            text-align: center;
            vertical-align: middle;
            color: #1e40af;
            min-width: 200px;
        }

        /* 普通内容单元格 (角色与状态交叉点) */
        .cell-content {
            display: table-cell;
            border: 1px solid #e2e8f0;
            padding: 12px 10px;
            vertical-align: top;
            background-color: #ffffff;
            transition: background 0.1s ease;
            min-width: 200px;
        }

        /* 流程方框卡片 */
        .process-card {
            background: #ffffff;
            border-radius: 14px;
            border-left: 5px solid #3b82f6;
            box-shadow: 0 2px 6px rgba(0,0,0,0.05);
            margin-bottom: 8px;
            padding: 12px 10px;
            transition: all 0.2s;
        }

        .process-card:last-child {
            margin-bottom: 0;
        }

        .card-title {
            font-weight: 700;
            font-size: 1rem;
            color: #0c4a6e;
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
            border-bottom: 1px dashed #cbd5e1;
            padding-bottom: 5px;
        }

        .card-title i {
            color: #3b82f6;
            font-size: 0.9rem;
        }

        .action-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 6px;
        }

        .action-badge {
            background: #f1f5f9;
            border-radius: 40px;
            padding: 5px 12px;
            font-size: 0.75rem;
            font-weight: 500;
            color: #0f172a;
            cursor: pointer;
            transition: 0.1s;
            border: 1px solid #cbd5e1;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .action-badge:hover {
            background: #e0e7ff;
            border-color: #3b82f6;
            transform: translateY(-1px);
        }

        /* 线条(连接线)容器, 采用svg绝对定位技术绘制连线 */
        .lines-container {
            position: relative;
            width: 100%;
            height: 0;
            pointer-events: none;
        }

        .diagram-relative {
            position: relative;
        }

        svg.connection-svg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 10;
        }

        svg.connection-svg path {
            pointer-events: stroke;
            cursor: pointer;
        }

        .line-label {
            font-size: 11px;
            fill: #334155;
            font-weight: 500;
            dominant-baseline: middle;
            text-anchor: middle;
            pointer-events: none;
            background: rgba(255,255,240,0.7);
        }

        /* 工具提示浮动层（自定义显示条件细节） */
        .custom-tooltip {
            position: fixed;
            background: #1e293b;
            color: #f1f5f9;
            padding: 8px 14px;
            border-radius: 12px;
            font-size: 0.8rem;
            max-width: 260px;
            z-index: 2000;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            pointer-events: none;
            transition: opacity 0.15s;
            font-weight: normal;
            letter-spacing: 0.3px;
            border-left: 4px solid #facc15;
            backdrop-filter: blur(4px);
        }

        /* 起始结束标记特殊样式 */
        .start-end-badge {
            background: #e6f7e6;
            border-left-color: #10b981;
        }

        .start-icon, .end-icon {
            font-size: 0.7rem;
            background: #d1fae5;
            border-radius: 20px;
            padding: 2px 8px;
            display: inline-block;
            margin-left: 8px;
        }

        .info-placeholder {
            color: #94a3b8;
            font-size: 0.75rem;
            text-align: center;
            padding: 12px 4px;
            font-style: italic;
        }

        /* 角色行列调整 */
        .matrix {
            display: table;
        }

        /* 确保svg覆盖正确 */
        .relative-wrapper {
            position: relative;
            margin-top: 10px;
        }

        /* 响应式小屏 */
        @media (max-width: 768px) {
            .role-header-cell, .state-header-cell, .cell-content {
                min-width: 140px;
            }
        }
    </style>
</head>
<body>
<div id="app">
    <div class="app-container">
        <h1><i class="fas fa-project-diagram"></i> 跨职能流程图 · 状态驱动</h1>
        <div class="sub">
            <i class="fas fa-arrow-right"></i> 横向：流程状态（包含开始/结束）&nbsp;&nbsp;|&nbsp;&nbsp;
            <i class="fas fa-users"></i> 纵向：人员角色组 &nbsp;&nbsp;|&nbsp;&nbsp;
            <i class="fas fa-mouse-pointer"></i> 悬停条件名称查看条件细节，点击action高亮线条(预览)
        </div>
        <!-- 流程图区域 -->
        <div class="diagram-wrapper" ref="diagramWrapper">
            <div class="relative-wrapper" ref="relativeWrapper">
                <!-- 表格矩阵 -->
                <div class="matrix" ref="matrixTable">
                    <!-- 表头: 第一列空白 + 各状态列 -->
                    <div class="matrix-row">
                        <div class="role-header-cell">角色组 / 状态</div>
                        <div v-for="state in states" :key="state.name" class="state-header-cell">
                            <div><strong>{{ state.name }}</strong></div>
                            <div v-if="state.isStart" class="start-icon"><i class="fas fa-play"></i> 开始</div>
                            <div v-else-if="state.isEnd" class="start-icon end-icon"><i class="fas fa-flag-checkered"></i> 结束</div>
                        </div>
                    </div>
                    <!-- 循环每一行角色 -->
                    <div v-for="role in roles" :key="role.id" class="matrix-row">
                        <div class="role-header-cell">
                            <i class="fas fa-user-tag"></i> {{ role.name }}
                        </div>
                        <!-- 每个状态单元格 -->
                        <div v-for="state in states" :key="state.name" class="cell-content" :data-state="state.name" :data-role="role.name" :data-cellkey="`${role.name}|${state.name}`">
                            <!-- 该角色在该状态下的流程方框（多个）一般一个状态只有一个方框，但为了扩展可多个，展示全部cards -->
                            <template v-for="card in getCardsForCell(role.name, state.name)">
                                <div class="process-card" :class="{'start-end-badge': state.isStart || state.isEnd}" :data-cardid="card.id">
                                    <div class="card-title">
                                        <i class="fas fa-cube"></i> {{ card.name || '流程节点' }}
                                    </div>
                                    <!-- 展示内部actions -->
                                    <div class="action-list">
                                        <span v-for="action in card.actions" :key="action.actionId" class="action-badge"
                                              @mouseenter="showActionTooltip($event, action)"
                                              @mouseleave="hideTooltip"
                                              @click="highlightTransitionsFrom(action, card, state, role)">
                                            <i class="fas fa-bolt"></i> {{ action.name }}
                                        </span>
                                        <span v-if="!card.actions.length" class="info-placeholder">无操作</span>
                                    </div>
                                </div>
                            </template>
                            <div v-if="getCardsForCell(role.name, state.name).length === 0" class="info-placeholder">
                                —
                            </div>
                        </div>
                    </div>
                </div>
                <!-- SVG 连线层 -->
                <svg class="connection-svg" ref="svgCanvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;"></svg>
            </div>
        </div>
        <div style="margin-top: 16px; font-size: 12px; color: #475569; text-align: center; border-top: 1px solid #e2e8f0; padding-top: 12px;">
            <i class="fas fa-info-circle"></i> 说明：线条代表从“源状态的特定action”到“目标状态”；条件名称显示在线上，鼠标悬停条件文字显示细节。点击action高亮相关连线。
        </div>
    </div>
</div>

<script>
// 默认的示例JSON数据结构。完全符合规范：
// 包含 states (横向，包含开始和结束), roles (纵向), transitions (定义每个action引出线条+条件)
// cards: 每个单元格(角色+状态) 下可以有多个process-card，每个卡片内部有多个actions。
// 注意：开始状态与结束状态不需要强制包含action，但作为流程节点存在。默认的开始结束也会展示方框(通常开始结束无需action)
// 按照业务: transitions 定义 sourceState, sourceRole, actionId(指某个卡片中的action标识), 目标 targetState, conditionName, conditionDetail。
const DEFAULT_JSON = {
    "states": [
        { "name": "草稿", "isStart": true, "isEnd": false },
        { "name": "评审中", "isStart": false, "isEnd": false },
        { "name": "已批准", "isStart": false, "isEnd": false },
        { "name": "已驳回", "isStart": false, "isEnd": false },
        { "name": "归档结束", "isStart": false, "isEnd": true }
    ],
    "roles": [
        { "id": "role_editor", "name": "编辑人员" },
        { "id": "role_reviewer", "name": "审核组" },
        { "id": "role_manager", "name": "管理员" }
    ],
    "cards": [
        { "id": "card_draft_editor", "role": "编辑人员", "state": "草稿", "name": "待编辑稿件", "actions": [
            { "actionId": "act_submit", "name": "提交评审", "description": "提交给审核组进行内容评审" }
        ] },
        { "id": "card_review_reviewer", "role": "审核组", "state": "评审中", "name": "内容审查", "actions": [
            { "actionId": "act_approve", "name": "批准", "description": "内容合格批准发布" },
            { "actionId": "act_reject", "name": "驳回", "description": "内容不合规退回修改" }
        ] },
        { "id": "card_approved_manager", "role": "管理员", "state": "已批准", "name": "发布确认", "actions": [
            { "actionId": "act_publish", "name": "归档发布", "description": "正式归档并结束流程" }
        ] },
        { "id": "card_rejected_editor", "role": "编辑人员", "state": "已驳回", "name": "修改稿", "actions": [
            { "actionId": "act_resubmit", "name": "重新提交", "description": "修改后再次进入评审" }
        ] },
        // 开始状态通常无动作，但是为了展示开始节点，也可以不加action，结束状态同理
        { "id": "card_start_all", "role": "编辑人员", "state": "草稿", "name": "初始草稿箱", "actions": [] } // 示例冗余，展示无action
    ],
    "transitions": [
        { "id": "t1", "sourceState": "草稿", "sourceRole": "编辑人员", "actionId": "act_submit", "targetState": "评审中", "conditionName": "内容完整", "conditionDetail": "稿件必须包含标题、正文和摘要，且字数不少于300字。" },
        { "id": "t2", "sourceState": "评审中", "sourceRole": "审核组", "actionId": "act_approve", "targetState": "已批准", "conditionName": "质量达标", "conditionDetail": "内容无错误，符合发布标准且图片版权清晰。" },
        { "id": "t3", "sourceState": "评审中", "sourceRole": "审核组", "actionId": "act_reject", "targetState": "已驳回", "conditionName": "严重问题", "conditionDetail": "包含事实错误、敏感词或结构混乱，需重新编辑。" },
        { "id": "t4", "sourceState": "已批准", "sourceRole": "管理员", "actionId": "act_publish", "targetState": "归档结束", "conditionName": "归档确认", "conditionDetail": "最终发布至归档库并通知相关人员。" },
        { "id": "t5", "sourceState": "已驳回", "sourceRole": "编辑人员", "actionId": "act_resubmit", "targetState": "评审中", "conditionName": "修改后复审", "conditionDetail": "根据驳回意见修改，重新进入评审环节。" },
        // 附加一个分支示例：同一个action在某种条件下也可以走向不同目标，例如从评审中“批准”根据不同条件走向已批准或者直接结束？为了展示线条上条件，增加一个从已批准由于特殊action但非必要
        { "id": "t6", "sourceState": "评审中", "sourceRole": "审核组", "actionId": "act_approve", "targetState": "归档结束", "conditionName": "免发布快速归档", "conditionDetail": "针对小改动直接归档，跳过管理员发布步骤。" }
    ]
};

Vue.component('flow-diagram', { // 直接在根实例中实现，但为了规范所有逻辑在根组件
});

new Vue({
    el: '#app',
    data() {
        return {
            // 实际流程图数据
            states: [],
            roles: [],
            cards: [],
            transitions: [],
            tooltipVisible: false,
            tooltipContent: '',
            tooltipX: 0,
            tooltipY: 0,
            // 用于高亮线条的临时存储
            highlightTransitionIds: new Set(),
            resizeObserver: null,
        };
    },
    mounted() {
        this.loadData(DEFAULT_JSON);
        window.addEventListener('resize', this.debouncedDrawLines);
        this.$nextTick(() => {
            this.drawLines();
        });
    },
    beforeDestroy() {
        window.removeEventListener('resize', this.debouncedDrawLines);
        if (this.resizeObserver) this.resizeObserver.disconnect();
    },
    methods: {
        loadData(jsonData) {
            this.states = jsonData.states || [];
            this.roles = jsonData.roles || [];
            this.cards = jsonData.cards || [];
            this.transitions = jsonData.transitions || [];
            // 确保开始结束状态存在，若未标记，但按照需求始终有开始结束；这里json已经包含开始和结束状态
            if (!this.states.some(s => s.isStart)) {
                this.states.unshift({ name: "开始", isStart: true, isEnd: false });
            }
            if (!this.states.some(s => s.isEnd)) {
                this.states.push({ name: "结束", isStart: false, isEnd: true });
            }
            this.$nextTick(() => {
                this.drawLines();
            });
        },

        // 获取指定角色+状态下的流程卡片列表
        getCardsForCell(roleName, stateName) {
            return this.cards.filter(card => card.role === roleName && card.state === stateName);
        },

        // 根据源角色、源状态、actionId 获取所有可能的转移（线条）
        getTransitionsFromAction(sourceRole, sourceState, actionId) {
            return this.transitions.filter(t => 
                t.sourceRole === sourceRole && t.sourceState === sourceState && t.actionId === actionId
            );
        },

        // 高亮对应的线条，点击action时调用
        highlightTransitionsFrom(action, card, sourceStateObj, sourceRoleObj) {
            const actionId = action.actionId;
            const sourceRole = sourceRoleObj.name;
            const sourceState = sourceStateObj.name;
            const transitionsList = this.getTransitionsFromAction(sourceRole, sourceState, actionId);
            if (transitionsList.length) {
                // 临时高亮: 清除之前的, 设置新高亮set
                this.highlightTransitionIds.clear();
                transitionsList.forEach(t => this.highlightTransitionIds.add(t.id));
                // 重绘线条，带高亮效果
                this.drawLines();
                // 3秒后自动取消高亮
                clearTimeout(this.highlightTimer);
                this.highlightTimer = setTimeout(() => {
                    this.highlightTransitionIds.clear();
                    this.drawLines();
                }, 2500);
            } else {
                // 没有连线提醒
                this.showTempMessage(`"${action.name}" 未定义任何流向条件`, 1500);
            }
        },

        showTempMessage(msg, duration) {
            const tipDiv = document.createElement('div');
            tipDiv.innerText = msg;
            tipDiv.style.position = 'fixed';
            tipDiv.style.bottom = '20px';
            tipDiv.style.left = '50%';
            tipDiv.style.transform = 'translateX(-50%)';
            tipDiv.style.backgroundColor = '#334155';
            tipDiv.style.color = '#fff';
            tipDiv.style.padding = '6px 14px';
            tipDiv.style.borderRadius = '30px';
            tipDiv.style.fontSize = '12px';
            tipDiv.style.zIndex = 3000;
            document.body.appendChild(tipDiv);
            setTimeout(() => tipDiv.remove(), duration);
        },

        showActionTooltip(event, action) {
            const detail = action.description || '无详细说明';
            this.tooltipContent = `<strong>${action.name}</strong><br>${detail}`;
            const tooltipDiv = document.createElement('div');
            tooltipDiv.className = 'custom-tooltip';
            tooltipDiv.innerHTML = this.tooltipContent;
            document.body.appendChild(tooltipDiv);
            const updatePos = (e) => {
                tooltipDiv.style.left = (e.clientX + 15) + 'px';
                tooltipDiv.style.top = (e.clientY - 30) + 'px';
            };
            updatePos(event);
            this.activeTooltipDiv = tooltipDiv;
            const moveHandler = (e) => updatePos(e);
            document.addEventListener('mousemove', moveHandler);
            this.tooltipMoveHandler = moveHandler;
        },

        hideTooltip() {
            if (this.activeTooltipDiv) {
                this.activeTooltipDiv.remove();
                this.activeTooltipDiv = null;
            }
            if (this.tooltipMoveHandler) {
                document.removeEventListener('mousemove', this.tooltipMoveHandler);
                this.tooltipMoveHandler = null;
            }
        },

        // 核心绘图: 遍历所有transitions, 计算源卡片中指定action所处卡片元素的位置，以及目标状态所在单元格（同一行？不需要限制角色，目标状态一般是全局的某个状态单元格，根据目标状态查找其对应的单元格位置规则：目标单元格应该属于任意角色？跨职能图中目标可能指向某个特定角色+状态？但根据真实跨职能流程图，action从一个角色状态跳到另一个角色的某个状态, 需要指定目标角色和目标状态。
        // 由于transitions数据中需要包含目标角色？按照需求每个action的线条最终到下一个状态的方框，但方框位于特定角色下。为了灵活性，我们在transitions里增加targetRole字段，不破坏原有结构但扩展。
        // 为了适配JSON，我们在加载前为示例增加targetRole。如果原始数据无targetRole,默认采用当前来源角色的同角色下？但不符合实际业务，为了展示效果，我为每个transition加上targetRole字段。
        // 确保显示准确，修改示例JSON添加targetRole。同时保证线条绘制精确性。
        drawLines() {
            const svg = this.$refs.svgCanvas;
            if (!svg) return;
            const wrapper = this.$refs.relativeWrapper;
            if (!wrapper) return;
            const matrixTable = this.$refs.matrixTable;
            if (!matrixTable) return;
            // 清除所有现有线条
            while (svg.firstChild) svg.removeChild(svg.firstChild);
            
            const wrapperRect = wrapper.getBoundingClientRect();
            // 遍历所有transitions，获取起始点和结束点位置
            for (let trans of this.transitions) {
                // 找到源卡片: 需要找到 sourceRole, sourceState 以及 拥有actionId的卡片中的某一个（且卡片里包含指定action）
                const sourceCards = this.cards.filter(c => c.role === trans.sourceRole && c.state === trans.sourceState);
                let sourceCardElem = null;
                let sourceActionElem = null;
                for (let card of sourceCards) {
                    if (card.actions && card.actions.some(a => a.actionId === trans.actionId)) {
                        // 找到这张卡片元素
                        const cells = document.querySelectorAll(`.cell-content[data-role="${trans.sourceRole}"][data-state="${trans.sourceState}"]`);
                        if (cells.length) {
                            const cardDivs = cells[0].querySelectorAll('.process-card');
                            for (let cd of cardDivs) {
                                // 通过卡片名称简单匹配, 更稳妥通过data-cardid
                                const cardTitleElem = cd.querySelector('.card-title');
                                if (cardTitleElem && cardTitleElem.innerText.includes(card.name)) {
                                    sourceCardElem = cd;
                                    // 找到对应的action badge
                                    const actionSpans = cd.querySelectorAll('.action-badge');
                                    for (let actSpan of actionSpans) {
                                        if (actSpan.innerText.includes(trans.actionId) || actSpan.innerText.includes(card.actions.find(a=>a.actionId===trans.actionId)?.name)) {
                                            sourceActionElem = actSpan;
                                            break;
                                        }
                                    }
                                    break;
                                }
                            }
                        }
                        break;
                    }
                }
                if (!sourceCardElem || !sourceActionElem) {
                    // 尝试不依赖卡片名称, 寻找包含action文本的任意卡片
                    const fallbackCell = document.querySelector(`.cell-content[data-role="${trans.sourceRole}"][data-state="${trans.sourceState}"]`);
                    if(fallbackCell){
                        const anyCard = fallbackCell.querySelector('.process-card');
                        if(anyCard) sourceCardElem = anyCard;
                        const anyAction = fallbackCell.querySelector('.action-badge');
                        if(anyAction) sourceActionElem = anyAction;
                    }
                }
                // 目标元素: 寻找目标角色+目标状态下的单元格第一张卡片（或目标单元格中央）
                const targetRole = trans.targetRole || trans.sourceRole; // 兼容原数据没有目标角色则默认同角色，实际需扩展
                const targetState = trans.targetState;
                const targetCell = document.querySelector(`.cell-content[data-role="${targetRole}"][data-state="${targetState}"]`);
                let targetElem = targetCell;
                // 如果目标单元格内有卡片，定位到卡片中央更好
                let targetCard = targetCell ? targetCell.querySelector('.process-card') : null;
                let targetPointElem = targetCard || targetCell;
                
                if (sourceActionElem && targetPointElem) {
                    const startRect = sourceActionElem.getBoundingClientRect();
                    const endRect = targetPointElem.getBoundingClientRect();
                    const startX = (startRect.left + startRect.right) / 2 - wrapperRect.left;
                    const startY = (startRect.top + startRect.bottom) / 2 - wrapperRect.top;
                    const endX = (endRect.left + endRect.right) / 2 - wrapperRect.left;
                    const endY = (endRect.top + endRect.bottom) / 2 - wrapperRect.top;
                    
                    // 绘制曲线路径
                    const midX = (startX + endX) / 2;
                    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                    const d = `M ${startX} ${startY} C ${midX} ${startY}, ${midX} ${endY}, ${endX} ${endY}`;
                    path.setAttribute('d', d);
                    const isHighlight = this.highlightTransitionIds.has(trans.id);
                    path.setAttribute('stroke', isHighlight ? '#f97316' : '#64748b');
                    path.setAttribute('stroke-width', isHighlight ? '3' : '2');
                    path.setAttribute('fill', 'none');
                    path.setAttribute('stroke-dasharray', isHighlight ? 'none' : '4 2');
                    path.style.pointerEvents = 'stroke';
                    // 添加条件文字标签
                    const textPathId = `label-${trans.id}`;
                    const textPath = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                    const textContent = trans.conditionName || '条件';
                    textPath.setAttribute('dy', -8);
                    textPath.setAttribute('font-size', '10');
                    textPath.setAttribute('fill', '#334155');
                    textPath.setAttribute('font-weight', '500');
                    textPath.setAttribute('text-anchor', 'middle');
                    textPath.innerHTML = `<textPath href="#${textPathId}" startOffset="50%">${textContent}</textPath>`;
                    // 为了支持textPath需要定义路径id
                    const pathWithId = path.cloneNode();
                    pathWithId.setAttribute('id', textPathId);
                    svg.appendChild(pathWithId);
                    svg.appendChild(textPath);
                    // 添加悬停细节：鼠标悬停在整个path上时显示条件细节
                    const conditionDetail = trans.conditionDetail || '无详细信息';
                    const hoverGroup = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                    hoverGroup.setAttribute('d', d);
                    hoverGroup.setAttribute('stroke', 'transparent');
                    hoverGroup.setAttribute('stroke-width', '12');
                    hoverGroup.setAttribute('fill', 'none');
                    hoverGroup.style.cursor = 'pointer';
                    hoverGroup.addEventListener('mouseenter', (e) => {
                        const fakeEvent = { clientX: e.clientX, clientY: e.clientY };
                        const detailDiv = document.createElement('div');
                        detailDiv.className = 'custom-tooltip';
                        detailDiv.innerHTML = `<strong>条件: ${trans.conditionName}</strong><br>${conditionDetail}`;
                        document.body.appendChild(detailDiv);
                        detailDiv.style.left = (e.clientX + 15) + 'px';
                        detailDiv.style.top = (e.clientY - 30) + 'px';
                        const rm = () => detailDiv.remove();
                        hoverGroup.addEventListener('mouseleave', rm, { once: true });
                    });
                    svg.appendChild(hoverGroup);
                }
            }
        },

        debouncedDrawLines() {
            clearTimeout(this.drawTimer);
            this.drawTimer = setTimeout(() => this.drawLines(), 150);
        }
    },
    watch: {
        states: { deep: true, handler() { this.$nextTick(() => this.drawLines()); } },
        cards: { deep: true, handler() { this.$nextTick(() => this.drawLines()); } },
        transitions: { deep: true, handler() { this.$nextTick(() => this.drawLines()); } }
    }
});
// 修补示例transition加入targetRole便于显示真实线条流向（按照实际业务流程）
// 在 mounted 后给transitions增加合理目标角色
setTimeout(() => {
    if (window.app && window.app.transitions) {
        const transUp = [
            { id: "t1", targetRole: "审核组" }, { id: "t2", targetRole: "管理员" }, 
            { id: "t3", targetRole: "编辑人员" }, { id: "t4", targetRole: "管理员" },
            { id: "t5", targetRole: "审核组" }, { id: "t6", targetRole: "管理员" }
        ];
        window.app.transitions.forEach(t => {
            const upd = transUp.find(u => u.id === t.id);
            if (upd) t.targetRole = upd.targetRole;
            else t.targetRole = t.sourceRole;
        });
        window.app.drawLines();
    }
}, 100);
</script>
</body>
